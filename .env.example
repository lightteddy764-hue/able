# Copy these into Render → Environment → Environment Variables
# (do NOT commit your real .env — it is gitignored)

# MongoDB connection string (use MongoDB Atlas for cloud hosting)
MONGODB_URI=your_mongodb_connection_string

# Google Gemini API key for the AI chatbot
GEMINI_API_KEY=your_gemini_api_key

# Secret used to sign JWT auth tokens (use a long random string)
JWT_SECRET=your_long_random_secret

# Port — Render sets this automatically, leave unset in production
PORT=3000
